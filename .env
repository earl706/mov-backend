# ---------------------------------------------------------------------------
# Mov environment configuration. Copy to `.env` and adjust for your machine.
# ---------------------------------------------------------------------------

# Django
DJANGO_SECRET_KEY=dev-insecure-change-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database (PostgreSQL)
# Local dev: localhost (start DB with `docker compose up db redis -d` from repo root).
# Docker Compose backend container: set POSTGRES_HOST=db instead.
POSTGRES_DB=mov
POSTGRES_USER=mov
POSTGRES_PASSWORD=mov
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# Redis / Celery (optional for local runserver)
# Leave unset to use in-memory cache — no Redis required. Uncomment when Redis is running
# (e.g. `docker compose up redis -d` or `brew services start redis`).
# REDIS_URL=redis://localhost:6379/0
# CELERY_BROKER_URL=redis://localhost:6379/1
# CELERY_RESULT_BACKEND=redis://localhost:6379/2
CELERY_TASK_ALWAYS_EAGER=true

# JWT lifetimes (minutes / days)
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7

# ---------------------------------------------------------------------------
# Object storage. Set STORAGE_BACKEND to one of: local | s3 | spaces
# `s3` and `spaces` both use django-storages' S3 backend (Spaces is S3-compatible).
# ---------------------------------------------------------------------------
STORAGE_BACKEND=local

# Shared S3 / Spaces credentials
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=mov-media
AWS_S3_REGION_NAME=us-east-1
# For DigitalOcean Spaces set e.g. https://nyc3.digitaloceanspaces.com
AWS_S3_ENDPOINT_URL=
AWS_S3_CUSTOM_DOMAIN=

# Frontend
VITE_API_BASE_URL=http://localhost:8000/api
